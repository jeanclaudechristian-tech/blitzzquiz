{
  "expo": {
    "platforms": [
      "ios",
      "android"
    ],
    "name": "BlitzzQuiz",
    "slug": "mobile",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/Eclaire.png",
    "scheme": "blitzzquiz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blitzzquiz.collegeahuntsic"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/Eclaire.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.blitzzquiz.collegeahuntsic",
      "keystore": {
        "keystorePath": "./my-release-key.jks",
        "keystorePassword": "123456",
        "keyAlias": "my-key-alias",
        "keyPassword": "123456"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Eclaire.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.851398001859-vtiht025g0u89bsfh1jasok9f15nuu9u"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "97e152af-4bb5-42a9-af37-b8464bf15ea8"
      }
    },
    "owner": "dddemong",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/97e152af-4bb5-42a9-af37-b8464bf15ea8"
    }
  }
}
